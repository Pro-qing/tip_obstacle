              height: 80
              left: 40
              line width: 2
              text size: 6
              top: 430
              width: 200
            - Align Bottom: false
              Background Alpha: 0.800000011920929
              Background Color: 0; 0; 0
              Class: jsk_rviz_plugin/OverlayText
              Enabled: true
              Foreground Alpha: 0.800000011920929
              Foreground Color: 255; 255; 0
