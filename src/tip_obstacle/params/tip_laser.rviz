              height: 80
              left: 40
              line width: 2
              text size: 6
              top: 620
              width: 200
            - Align Bottom: false
              Background Alpha: 0.800000011920929
              Background Color: 0; 0; 0
              Class: jsk_rviz_plugin/OverlayText
              Enabled: true
              Foreground Alpha: 0.800000011920929
              Foreground Color: 255; 0; 0
              Invert Shadow: false
              Name: FATAL
              Overtake BG Color Properties: false
              Overtake FG Color Properties: false
              Overtake Position Properties: true
              Topic: /health_aggregator/fatal_text
              Value: true
              font: DejaVu Sans Mono
              height: 80
              left: 40
              line width: 2
              text size: 6
              top: 720
              width: 200
          Enabled: true
          Name: Health Checker
      Enabled: true
      Name: System
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 4.713416576385498
        Min Value: -2.3506851196289062
        Value: true
      Axis: Z
